[
  {
    "task": "text-to-speech",
    "base-model": "dots_tts",
    "params": [
      {
        "name": "numSteps",
        "type": "number",
        "componentType": "input-number",
        "componentProps": {
          "label": "推理步数",
          "min": 1,
          "step": 1
        },
        "required": true,
        "defaultValue": 10,
        "description": "dots_tts 流匹配采样步数。步数越大质量越高但速度越慢。"
      },
      {
        "name": "guidanceScale",
        "type": "string",
        "componentType": "input-number",
        "componentProps": {
          "label": "引导强度",
          "min": 0,
          "step": 0.1
        },
        "required": true,
        "defaultValue": "1.2",
        "description": "Classifier-free guidance 强度。值越大发音越清晰但可能引入失真。"
      },
      {
        "name": "speakerScale",
        "type": "string",
        "componentType": "input-number",
        "componentProps": {
          "label": "说话人强度",
          "min": 0,
          "step": 0.1
        },
        "required": true,
        "defaultValue": "1.5",
        "description": "说话人 embedding 缩放系数。控制音色匹配强度。"
      }
    ]
  },
  {
    "task": "voice-clone",
    "base-model": "dots_tts",
    "params": [
      {
        "name": "numSteps",
        "type": "number",
        "componentType": "input-number",
        "componentProps": {
          "label": "推理步数",
          "min": 1,
          "step": 1
        },
        "required": true,
        "defaultValue": 10,
        "description": "dots_tts 流匹配采样步数。步数越大质量越高但速度越慢。"
      },
      {
        "name": "guidanceScale",
        "type": "string",
        "componentType": "input-number",
        "componentProps": {
          "label": "引导强度",
          "min": 0,
          "step": 0.1
        },
        "required": true,
        "defaultValue": "1.2",
        "description": "Classifier-free guidance 强度。值越大发音越清晰但可能引入失真。"
      },
      {
        "name": "speakerScale",
        "type": "string",
        "componentType": "input-number",
