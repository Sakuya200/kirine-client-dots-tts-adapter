  },
  {
    "task": "model-training",
    "base-model": "dots_tts",
    "params": [
      {
        "name": "epochCount",
        "type": "number",
        "componentType": "input-number",
        "componentProps": {
          "label": "训练轮次",
          "min": 1,
          "step": 1
        },
        "required": true,
        "defaultValue": 5,
        "description": "模型训练的 epoch 数。"
      },
      {
        "name": "batchSize",
        "type": "number",
        "componentType": "input-number",
        "componentProps": {
          "label": "批次大小",
          "min": 1,
          "step": 1
        },
        "required": true,
        "defaultValue": 1,
        "description": "每个训练 step 使用的 batch size。"
      },
      {
        "name": "gradientAccumulationSteps",
        "type": "number",
        "componentType": "input-number",
        "componentProps": {
          "label": "梯度累积步数",
          "min": 1,
          "step": 1
        },
        "required": true,
        "defaultValue": 1,
        "description": "训练时的梯度累积步数。"
      },
      {
        "name": "learningRate",
        "type": "string",
        "componentType": "input-number",
        "componentProps": {
          "label": "学习率",
          "min": 0,
          "step": 0.000001
        },
        "required": true,
        "defaultValue": "2e-5",
        "description": "训练学习率，当前前端按字符串形式保存与透传。"
      },
      {
        "name": "weightDecay",
        "type": "string",
        "componentType": "input-number",
        "componentProps": {
          "label": "权重衰减",
          "min": 0,
          "step": 0.01
        },
        "required": true,
        "defaultValue": "0.1",
        "description": "优化器权重衰减。"
      },
      {
        "name": "warmupSteps",
        "type": "number",
        "componentType": "input-number",
        "componentProps": {
          "label": "Warmup 步数",
          "min": 0,
          "step": 1
        },
        "required": true,
        "defaultValue": 100,
        "description": "学习率 warmup 步数。"
      },
      {
        "name": "enableGradientCheckpointing",
        "type": "boolean",
        "componentType": "switch",
        "componentProps": {
          "label": "梯度检查点",
          "text": "启用梯度检查点"
        },
        "required": true,
        "defaultValue": false,
        "description": "是否启用 gradient checkpointing，节省显存但略微降低速度。"
      }
    ]
  }
